# Kopieer naar Vercel Environment Variables

# Neon Postgres connection string (Storage → Neon in Vercel dashboard)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Wachtwoord voor het kapper-portaal (/beheer — niet publiek gelinkt)
PORTAL_PASSWORD=Ronaldo7

# Optioneel: extra geheim voor portaal-tokens (anders PORTAL_PASSWORD)
PORTAL_SECRET=

# Google Places API voor reviews op de website
# Maak een sleutel aan in Google Cloud Console en zet Places API (New) aan
GOOGLE_PLACES_API_KEY=
# Optioneel: Place ID van Art of Cuts (standaard al ingevuld)
GOOGLE_PLACE_ID=ChIJ61Gk9d19E0cR4v3W9bO3Kq8
