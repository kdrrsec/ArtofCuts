# Kopieer naar Vercel Environment Variables

# Neon Postgres connection string (Storage → Neon in Vercel dashboard)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Wachtwoord voor het kapper-portaal (/beheer.html)
# Standaard: iQY2JIPurLcOISlj (overschrijf in Vercel voor extra veiligheid)
PORTAL_PASSWORD=iQY2JIPurLcOISlj

# Optioneel: extra geheim voor portaal-tokens (anders PORTAL_PASSWORD)
PORTAL_SECRET=
